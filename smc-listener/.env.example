# AWS SQS credentials from SMC UI portal (https://ui.smc-api.telenor.no)
# Generate a queue in the SMC UI and subscribe it to your league topics.
# You will receive a Queue URL, Access Key, and Secret Access Key.
SQS_QUEUE_URL=
SQS_ACCESS_KEY=
SQS_SECRET_ACCESS_KEY=
SQS_REGION=eu-north-1

# Next.js webhook URL for cache revalidation
# Example: https://ostersif.se/api/revalidate-match
NEXTJS_WEBHOOK_URL=

# Secret key for authenticating webhook calls (must match SERVICE_BUS_REVALIDATE_SECRET in Next.js env)
SERVICE_BUS_REVALIDATE_SECRET=
